{
    "name": "hosteldavila/api",
    "description": "Hostel da Vila Backend API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "firebase/php-jwt": "^6.10",
        "monolog/monolog": "^3.7",
        "vlucas/phpdotenv": "^5.6",
        "respect/validation": "^2.3",
        "guzzlehttp/guzzle": "^7.9",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=5"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}
