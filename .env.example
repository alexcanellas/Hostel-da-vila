# Aplicação
APP_ENV=development
APP_DEBUG=true
APP_NAME="Hostel da Vila API"
APP_URL=http://localhost:8080

# JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
JWT_EXPIRATION=86400

# Banco de dados
DB_HOST=db
DB_PORT=3306
DB_DATABASE=hosteldavila
DB_USERNAME=hosteldavila
DB_PASSWORD=senha_segura
DB_ROOT_PASSWORD=senha_root_segura

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudbeds
CLOUDBEDS_CLIENT_ID=
CLOUDBEDS_CLIENT_SECRET=
CLOUDBEDS_REDIRECT_URI=
CLOUDBEDS_PROPERTY_ID=
CLOUDBEDS_WEBHOOK_SECRET=

# Getnet
GETNET_CLIENT_ID=
GETNET_CLIENT_SECRET=
GETNET_SELLER_ID=
GETNET_ENV=sandbox

# Kommo CRM
KOMMO_CLIENT_ID=
KOMMO_CLIENT_SECRET=
KOMMO_SUBDOMAIN=
KOMMO_REDIRECT_URI=
KOMMO_WEBHOOK_SECRET=

# HSystem
HSYSTEM_API_URL=
HSYSTEM_API_KEY=
HSYSTEM_HOTEL_ID=

# E-mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@hosteldavila.com.br
MAIL_FROM_NAME="Hostel da Vila"

# Log
LOG_LEVEL=debug
LOG_PATH=/var/www/storage/logs/app.log
